{
  "manifest_version": 2,
  "name": "Detector de Privacidade",
  "version": "1.0",
  "description": "Extensão simples para detectar sinais de rastreamento e privacidade em páginas web.",
  
  "permissions": [
    "webRequest",
    "cookies",
    "tabs",
    "<all_urls>"
  ],


  "background": {
    "scripts": ["monitoramento.js"]
  },


  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["pagina.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_action": {
    "default_title": "Detector de Privacidade",

    "default_popup": "painel.html"

  }
}